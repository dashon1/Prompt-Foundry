{
  "prompt_generator": {
    "category": "elearning_builder",
    "type": "prompt_generator",
    "inputs": {
      "topic": "{{topic}}",
      "audience_level": "{{audience_level}}"
    },
    "template": "5-lesson module for {{topic}} ({{audience_level}}): outcomes, lesson beats, project, quiz items."
  },
  "agent_helper": {
    "category": "elearning_builder",
    "type": "agent_helper",
    "checks": [
      "Measurable outcomes",
      "Scope per lesson",
      "Assessment present",
      "No credential claims"
    ]
  },
  "general": {
    "category": "elearning_builder",
    "type": "general",
    "inputs": {
      "topic": "{{topic}}"
    }
  }
}